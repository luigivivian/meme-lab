# === Required ===
GOOGLE_API_KEY=your-google-api-key-here

# === Database (MySQL) ===
DATABASE_URL=mysql+aiomysql://root:masterkey@localhost/memelab

# === Optional: Paid Google API (higher quotas) ===
GOOGLE_API_KEY_PAID=your-paid-google-api-key-here

# === Optional: Anthropic (legacy, replaced by Gemini) ===
ANTHROPIC_API_KEY=your-anthropic-key-here

# === Optional: Kie API ===
KIE_API_KEY=your-kie-api-key-here

# === Optional: LLM Backend ===
LLM_BACKEND=ollama
OLLAMA_MODEL=gemma3:4

# === Optional: Video generation ===
VIDEO_ENABLED=true
GCS_BUCKET_NAME=your-gcs-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# === Optional: BlueSky posting ===
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=your-app-password

# === Image backend priority ===
IMAGE_BACKEND_PRIORITY=comfyui
#IMAGE_BACKEND_PRIORITY=gemini
